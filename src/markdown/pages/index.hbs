<!doctype html>
<html lang="en">
  <head>
    {{> layout/head}}
  </head>

  <body>

     {{!-- SITE OVERLAY --}}
     <div id="site-overlay" class="fixed inset-0 bg-black/20 z-40  opacity-0 pointer-events-none  transition-opacity smx:hidden"></div>

    
    <div class="flex flex-col min-h-[100dvh]">
      {{> layout/header}}

      <main class="flex-1 flex flex-col justify-end">
        {{> sections/hero}}
        {{> sections/features}}
        {{> sections/tech}}
        {{> sections/compare}}
        {{> sections/installation}}
        {{> sections/steps}}
        {{> sections/products-vitrine}}
        {{> sections/consultation}}
        {{> sections/septic-form}}
        {{> sections/species}}
        {{> sections/works}}
        {{> sections/install-self}}
        {{> sections/signup}}
        {{> sections/process-videos}}
        {{> sections/faq}} 
        {{> sections/map}}
      </main>

      {{> layout/footer}}
    </div>

    {{> components/modal}} 

    {{> components/success-modal}} 
    
    {{> components/product-modal}} 

    {{> components/burger-modal}} 
    
    {{> layout/footer-scripts}}
  </body>
</html>
