<footer class="bg-dark-tertiary border-t border-neutral-200">
  <div class="eco-container">
    <!-- ================= TOP ROW ================= -->
    <div
      class="grid grid-cols-1 gap-pad-40 pt-[0.4375rem] pb-[0.75rem] smx:py-[1.5625rem] smx:grid-cols-12"
    >
      <!-- COL 1 (4/12) LOGO -->
      <div
        class="mb-3 smx:mb-0 flex flex-col gap-1 text-center items-center smx:max-w-[13.5rem] smx:col-span-4 smx:text-left mds:items-start"
      >
        <div class="w-[11.5625rem] mdx:w-[11rem]">
          <img
            src="/images/webp/logo.webp"
            alt="logo"
            class="w-full h-auto object-cover"
          />
        </div>

        <p class="text-caption leading-[1.6] text-light-base smx:max-w-[11.25rem]">
          Автономные канализации с доставкой <br class="hidden smx:block" />
          и установкой в Москве
        </p>
      </div>

      <!-- COL 2 (5/12) CONTACTS -->
      <div class="mb-3 smx:mb-0 smx:col-span-5 flex flex-col gap-[0.75rem] smx:gap-pad-16">

        <div class="flex flex-row justify-between smx:justify-[initial] smx:flex-col gap-[0.75rem] smx:gap-pad-16">
          <div class="flex items-center gap-pad-8">
            <svg class="w-5 h-5 text-brand-main shrink-0">
              <use href="/icons/sprite/sprite.svg#whatsapp"></use>
            </svg>
            <span class="text-nowrap text-caption leading-[1.6] uppercase font-unbounded text-light-base">+7 (913) 555-0199</span>
          </div>

          <div class="flex items-center gap-pad-8">
            <svg class="w-4 h-4 text-brand-main shrink-0">
              <use href="/icons/sprite/sprite.svg#mail"></use>
            </svg>
            <span class="text-caption text-light-base text-nowrap"
              >info@septiki-spb.com</span
            >
          </div>
        </div>

        <div class="flex items-center gap-pad-8">
          <svg class="w-4 h-4 text-brand-main shrink-0 mt-[0.125rem]">
            <use href="/icons/sprite/sprite.svg#pin"></use>
          </svg>
          <span class="text-caption text-light-base">
            г. Санкт-Петербург, пр-кт Космонавтов, д. 42, литера А, помещ. 3-Н,
            офис 2
          </span>
        </div>
      </div>

      <!-- COL 3 (3/12) BUTTON -->
      <div class="smx:col-span-3 flex justify-end">
        {{> components/button-transparent-green modalCallback="true"
        text="Заказать звонок" class="w-full smx:w-auto" disabled=false }}
      </div>
    </div>

    <!-- ================= border-[0.0625rem] ================= -->
    <div class="border-t border-neutral-200"></div>

    <!-- ================= BOTTOM ROW ================= -->
    <div
      class="flex flex-col smx:flex-row items-center justify-between py-[0.625rem] pb-[1.25rem] gap-[0.375rem] smx:pt-[1.25rem] smx:gap-pad-12 mds:pt-[1.875rem]"
    >
      <!-- LEFT -->
      <div class="text-caption text-light-secondary text-center smx:text-left">
        © 2026 AquaTech Engineering. All rights reserved.
      </div>

      <!-- RIGHT -->
      <div
        class="flex gap-pad-24 text-caption text-light-secondary mds:pr-pad-80"
      >
        <a href="#" target="_blank" class="hover:text-brand-one hover:underline transition">
          Privacy Policy
        </a>

        <a href="#" target="_blank" class="hover:text-brand-one hover:underline transition">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
