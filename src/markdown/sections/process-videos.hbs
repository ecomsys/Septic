<section class="section-y-padding bg-white">
  <div class="eco-container flex flex-col gap-[20px] smx:gap-[32px] mdx:gap-[50px]">
    <!-- ROW 1 -->
    <div class="flex flex-col gap-[12px] text-center">

      <h2 class="section-title max-w-[1160px] mx-auto">
        Посмотрите <span class="text-brand-main">короткие видео</span> об
        автономных канализациях
      </h2>
      <p class="text-[16px] text-light-secondary leading-[1.6]">
        Как происходит профессиональный монтаж автономной канализации?
      </p>
    </div>

    <!-- ROW 2 -->
    <div class="relative flex flex-col gap-[8px] smx:gap-[16px] mdx:gap-[24px]">
      <!-- NAVIGATION -->
      {{> components/slider-navigation navId="process-slider-nav"
      paginationClass="process-pagination" }}

      <!-- SLIDER -->
      <div class="swiper" id="process-slider">
        <div class="swiper-wrapper">
          <!-- SLIDE -->
          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-1.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>

          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-2.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>

          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-3.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>

          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-1.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>

          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-2.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>

          <div
            class="swiper-slide bg-gray-100 h-[300px] rounded-[16px] flex items-center justify-center"
          >
            <img
              src="/images/webp/videos/youtube-3.webp"
              class="w-full h-full object-cover"
              alt="Youtube"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
