<section class="bg-gray-50">
  <div class="faq-bg eco-container section-y-padding  flex flex-col gap-[16px] mdx:gap-[24px]">    
    <!-- TITLE -->
    <h2 class="section-title">
      Часто задаваемые <span class="text-brand-main">вопросы</span>
    </h2>

    <!-- ACCORDION -->
 
    <div class="flex flex-col gap-[8px] smx:gap-[12px] max-w-[768px] mx-auto" id="faq">

      {{> components/faq-item 
        activeClass="active "
        title="Чем отличается обычный септик от станции глубокой биологической очистки?"
        content="Главное отличие — степень очистки и необходимость в откачке. Обычный септик отстаивает стоки, очищая их максимум на 60–70%. Получившуюся воду необходимо доочищать в грунте (поля фильтрации), а твердые осадки накапливаются — их вызывают ассенизатором раз в 1–2 года. Станция биологической очистки использует аэрацию (кислород) и активный ил, очищая воду на 95–98%. Такую воду можно сливать в канаву или поливать газон, а ил достают ведром раз в 3–6 месяцев. Откачка машиной не нужна."
      }}

      {{> components/faq-item 
        title="Можно ли пользоваться канализацией зимой и как её консервировать, если дом не отапливается?"
        content="В среднем монтаж занимает 1–2 дня в зависимости от условий."
      }}

      {{> components/faq-item 
        title="Как часто нужно откачивать автономную канализацию и куда девают очищенные стоки?"
        content="Да, установка возможна круглый год при соблюдении технологии."
      }}

      {{> components/faq-item 
        title="Что нельзя смывать в канализацию с автономной очисткой (вредные вещества)?"
        content="В большинстве случаев нет, но зависит от участка."
      }}

      {{> components/faq-item 
        title="Что делать, если отключили электричество (для станций)?"
        content="Да, мы предоставляем гарантию на оборудование и монтаж."
      }}

    </div>

    <!-- BUTTON -->   
      {{> components/button-blue id="faq-btn-callback" text="Задать вопрос"
      class="h-[48px] w-full max-w-[300px] mx-auto smx:mt-[8px] mdx:mt-[12px]" disabled=false }}
   
  </div>
</section>




