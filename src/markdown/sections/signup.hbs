<section class="bg-[#f6f6f6] relative">
  <div class="eco-container py-[40px] smx:py-[64px] mdx:py-[116px] relative overflow-hidden z-10">

    <div class="bg-[#f6f6f6] absolute inset-0 -z-15"></div>

    {{!-- signup bg --}}
    <div class="absolute inset-0 -z-12">
      <img src="/images/webp/signup/signup-bg.webp" class="w-full h-full object-cover 
      -translate-y-[17%] translate-x-[45%]   
      md:translate-y-[initial] md:translate-x-[initial]
      ">
    </div>

    <div class="flex flex-col gap-[40px]">
      <!-- CARDS WRAPPER -->
      <div
        class="flex flex-col md:flex-row gap-[8px] smx:gap-[20px] mdx:gap-[40px] justify-between"
      >
        <!-- ================= LEFT CARD ================= -->
        <div class="md:max-w-[450px] w-full flex flex-col gap-[16px] mdx:gap-[20px]">
          <h3 class="text-[14px] smx:text-[16px] mdx:text-[20px] uppercase font-unbounded text-light-base">
            запишитесь на
            <span class="text-brand-main">бесплатный выезд</span> замерщика на
            участок
          </h3>

          <p class="text-[18px] text-light-secondary leading-[1.6] font-inter">
            Замерщик определит уровень грунтовых вод и оптимальное
            месторасположение для установки септика
          </p>

          <!-- LIST ITEM -->
          <div class="flex flex-col smx:flex-row w-full md:flex-col gap-[24px] smx:gap-[16px] smx:mt-[16px]">
            <!-- ITEM 1 -->
            <div
              class="w-full smx:w-[30%] md:w-[initial] bg-white rounded-[8px] p-[8px] smx:p-[16px] mdx:p-[24px] flex flex-col gap-[6px]"
            >
              <div class="flex items-center gap-[8px]">
                <svg class="w-6 h-6 text-brand-one shrink-0">
                  <use href="/icons/sprite/sprite.svg#calendar-days"></use>
                </svg>
                <span class="text-[12px] text-light-base font-unbounded uppercase leading-[1.6]"
                  >Дата и время</span
                >
              </div>
              <p class="text-body-small text-light-secondary">
                Инженер приедет к Вам в будний день или выходные
              </p>
            </div>

            <!-- ITEM 2 -->
            <div
              class="w-full smx:w-[30%] md:w-[initial] bg-white rounded-[8px] p-[8px] smx:p-[16px] mdx:p-[24px] flex flex-col gap-[6px]"
            >
              <div class="flex items-center gap-[8px]">
                <svg class="w-6 h-6 text-brand-one shrink-0">
                  <use href="/icons/sprite/sprite.svg#ruler-dimension"></use>
                </svg>
                <span class="text-[12px] text-light-base font-unbounded uppercase leading-[1.6]">Замер бесплатен</span>
              </div>
              <p class="text-body-small text-light-secondary">
                Замер бесплатен и ни к чему Вас не обязывает   

              </p>
            </div>
          </div>
        </div>

        <!-- ================= RIGHT CARD ================= -->
        <div
          class="md:max-w-[443px] signup-shadow rounded-big p-[16px] smx:p-[24px] mdx:p-[40px] w-full flex flex-col gap-[12px] mdx:gap-[20px]"
        >
          <h3 class="text-[14px] smx:text-[16px] mdx:text-[20px] uppercase font-unbounded text-light-base">
            Выберите удобный день для выезда замерщика
          </h3>

          <p class="text-[14px] smx:text-[16px] text-black leading-[1.6]">
            Наш специалист свяжется с вами через 5 минут, чтобы уточнить детали
          </p>

          <!-- FORM -->
          <form id="signup-form" class="flex flex-col gap-[8px] smx:gap-[16px]">

            <!-- INPUT DATE -->
            <div class="flex flex-row md:flex-col gap-[8px] mdx:gap-[16px]">
              {{> components/input-field
                type="text"
                placeholder="Выберите дату"
                name="sugnup-date"
                icon="calendar-days"
                isDate=true
              }}
                <!-- INPUT PHONE -->
              {{> components/input-field
                type="text"
                name="signup-phone"
                placeholder="Ваш телефон +7 (ххх) ххх хххх"               
              }}       
            </div>
          

            <!-- BUTTON -->
            {{> components/button-blue id="signup-submit" type="submit" text="Перезвоните
            мне" class="w-full h-[48px] smx:h-[60px] mdx:mt-[12px]" disabled=false }}

            <!-- CHECKBOX -->
            {{> components/check-line
              requred="true"
              name="signup-policy"
              text="Нажимая на кнопку вы соглашаетесь с условиями пользовательского соглашения"
            }}
                      
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
