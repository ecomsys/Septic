<div class="swiper-slide bg-white flex flex-col h-full rounded-[0.5rem] overflow-hidden select-none">

  <!-- IMAGE -->
  <div class="aspect-[372/219] smx:aspect-[222/219] mdx:aspect-[322/219] w-full">
    <img 
      src="{{img}}" 
      alt="{{alt}}" 
      class="w-full h-full object-cover"
    />
  </div>

  <!-- CONTENT -->
  <div class="flex flex-col gap-[0.5rem] p-[1rem] pb-[1.25rem] flex-1">

    <!-- TITLE -->
    <h3 class="uppercase text-[0.875rem] leading-[1.4] font-unbounded text-[#052e16]">
      {{title}} 
    </h3>

    <!-- USERS -->
    <div class="flex items-center justify-between mb-1">
      <span class="text-[0.75rem] smx:text-[0.75rem] text-[#052e16] leading-[1.6]">
        Количество пользователей
      </span>
      <span class="text-brand-one text-[0.75rem] uppercase leading-[1.6]">
        {{users}}
      </span>
    </div>

    <!-- PRICE -->
    <div class="flex justify-end items-center gap-1 mdx:gap-3 mt-auto">

      {{#if oldPrice}}
      <span class="text-[0.875rem] text-[#475569] line-through leading-[1.6]">
        {{oldPrice}}
      </span>
      {{/if}}

      <span class="text-[1rem] font-unbounded text-brand-one uppercase leading-[1.4] font-bold">
        {{price}}
      </span>
    </div>

  </div>

  <!-- BUTTON -->
  <button
    data-productmodal="true"
    type="button"
    class="h-[3.125rem] bg-brand-one text-white text-[0.875rem] uppercase font-unbounded flex items-center justify-center 
           w-full rounded-b-[0.5rem] hover:bg-brand-one-darkest active:bg-brand-main-darkest transition cursor-pointer"
  >
    <span>Подробнее</span>
  </button>

</div>