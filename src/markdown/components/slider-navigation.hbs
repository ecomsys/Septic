<div id="{{navId}}" class="flex items-center justify-end gap-[0.75rem] {{hideClass}}">
  <!-- PREV -->
  <button
    class="slider-prev shrink-0 w-[3.9375rem] h-[1.75rem] flex items-center justify-center cursor-pointer text-bg-darkest disabled:text-slate-300"
  >
    <svg class="w-8 h-3 transition-transform">
      <use href="/icons/sprite/sprite.svg#left"></use>
    </svg>
  </button>

  <!-- PAGINATION BAR -->
  <div class="{{paginationClass}} flex w-[3.75rem]">
    <!-- генерится динамически -->
  </div>

  <!-- NEXT -->
  <button
    class="slider-next shrink-0 w-[3.9375rem] h-[1.75rem] flex items-center justify-center cursor-pointer transition duration-200 bg-brand-one rounded-[1rem] hover:bg-brand-one-darkest active:bg-brand-main disabled:bg-slate-300"
  >
    <svg class="w-8 h-3 text-white">
      <use href="/icons/sprite/sprite.svg#right"></use>
    </svg>
  </button>
</div>
