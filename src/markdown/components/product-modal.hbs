<div
  id="product-modal-overlay"
  class="fixed inset-0 bg-black/20 z-50 flex md:items-center justify-center opacity-0 pointer-events-none transition"
>
  <button
      data-product-modal-close
      class="md:hidden flex z-100 cursor-pointer absolute top-[1rem] right-[1rem] w-[2rem] h-[2rem] items-center justify-center rounded-full hover:bg-black/10 transition"
    >
      <svg class="w-5 h-5 text-black">
        <use href="/icons/sprite/sprite.svg#close"></use>
      </svg>
    </button>

  <div
    id="product-modal-content"
    class="max-w-[100rem] w-full bg-white p-[1.25rem] smx:p-[2.5rem] mds:px-[2.5rem] md:px-[5rem] mdx:px-[15rem] relative overflow-auto scroll-hide"
  >
  
   <button
      data-product-modal-close
      class="hidden md:flex z-100 cursor-pointer absolute top-[1rem] right-[1rem] w-[2rem] h-[2rem] flex items-center justify-center rounded-full hover:bg-black/10 transition"
    >
      <svg class="w-5 h-5 text-black">
        <use href="/icons/sprite/sprite.svg#close"></use>
      </svg>
    </button>

    <!-- GRID -->
    <div class="flex flex-col md:flex-row items-center">
      <!-- LEFT: IMAGE -->
      <div class="w-full md:w-1/2">
        <div class="max-w-[33.8125rem] mx-auto mdx:mr-[initial]">
          <img
            src="/images/webp/products/eurolos.webp"
            alt="product"
            class="max-w-[33.8125rem] w-full h-full object-cover mx-auto"
          />
        </div>
      </div>

      <!-- RIGHT: CONTENT -->
      <div class="w-full md:w-1/2 flex flex-col gap-[1rem]">
        <!-- 1. TITLE -->
        <h2
          class="text-[1.75rem] font-unbounded uppercase leading-[1.6] text-light-base"
        >
          Евролос ЭКО 10
        </h2>

        <!-- 2. AVAILABILITY -->

        <div class="text-right text-caption text-light-base">
          Доступно: <span class="text-brand-main">в наличии</span>
        </div>

        <!-- INFO BLOCK-->
        <div class="flex justify-between gap-[1rem]">
          <!-- left CHARACTERISTICS -->
          <div class="flex flex-col gap-[0.5rem]">
            <div class="text-[0.875rem] leading-[1/6] text-light-base">
              Артикул: ЭКО-10
            </div>
            <!-- SPECS -->
            <ul
              class="text-[0.875rem] leading-[1/6] flex flex-col gap-[0.5rem] text-light-base"
            >
              <li>Характеристика 1: Lorem ipsum</li>
              <li>Характеристика 2: Lorem ipsum</li>
              <li>Характеристика 3: Lorem ipsum</li>
              <li>Характеристика 4: Lorem ipsum</li>
              <li>Характеристика 5: Lorem ipsum</li>
            </ul>
          </div>

          <!-- RIGHT PRICE  -->
          <div class="flex flex-col justify-center items-end text-right">
            <span
              class="line-through text-[1rem] text-light-secondary leading-[1.6]"
            >
              395 000 ₽
            </span>

            <span
              class="text-[1rem] font-bold text-brand-one uppercase leading-[1.4] font-unbounded"
            >
              295 000.00 ₽
            </span>

            <span class="border-[0.0625rem] border-slate-300 w-full mt-2 mb-2"></span>

            <span class="text-[1rem] text-brand-main leading-[1.6] mb-1">
              "под ключ"
            </span>

            <span
              class="text-[1.25rem] font-unbounded text-brand-one uppercase font-bold leading-[1.6]"
            >
              310 000.00 ₽
            </span>
          </div>
        </div>

        <!-- 4. FEATURES -->
        <div class="flex justify-between text-brand-main mt-6 mb-6">
          <div class="flex items-center gap-[0.5rem] px-4">
            <svg class="w-6 h-6">
              <use href="/icons/sprite/sprite.svg#van"></use>
            </svg>
            <span class="text-[0.75rem] uppercase font-unbounded"
              >Бесплатная доставка</span
            >
          </div>

          <div class="flex items-center gap-[0.5rem] px-4">
            <svg class="w-6 h-6">
              <use href="/icons/sprite/sprite.svg#coins"></use>
            </svg>
            <span class="text-[0.75rem] uppercase font-unbounded"
              >Можно в рассрочку</span
            >
          </div>
        </div>

        <!-- 5. BUTTONS -->
        <div class="grid grid-cols-1 smx:grid-cols-2 gap-[0.75rem] mt-[0.5rem]">
          {{> components/button-transparent-blue modalCallback="true"
          class="h-[3.75rem]" text="Вызвать инженера" disabled=false }}
           
           {{> components/button-blue modalCallback="true" class="h-[3.75rem]"
          text="Заказать" disabled=false }}
        </div>
      </div>
    </div>
  </div>
</div>
