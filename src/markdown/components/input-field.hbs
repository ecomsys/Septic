<div class="input-field relative w-full">

  <input
    type="{{type}}"
    name="{{name}}"
    placeholder="{{placeholder}}"
    class="w-full border border-neutral-200 rounded-[8px] px-[20px] py-[10px] text-body h-[60px]
    focus:outline-none focus:ring-2 focus:ring-slate-300 focus:border-slate-400 transition
    "
    data-input
    {{#if isDate}}data-datepicker readonly{{/if}}
  />

  {{#if icon}}
    <button
      type="button"
      class="input-trigger absolute right-[12px] top-1/2 -translate-y-1/2 bg-white"
      data-trigger
    >
      <svg class="w-6 h-6 text-brand-one pointer-events-none">
        <use href="/icons/sprite/sprite.svg#{{icon}}"></use>
      </svg>
    </button>
  {{/if}}

</div>