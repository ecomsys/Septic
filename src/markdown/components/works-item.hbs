<div class="relative gap-[2.8125rem] flex flex-col smx:grid smx:grid-rows-[1fr_1fr]">
  {{!--smx divider --}}
  <div
    class="hidden smx:flex absolute bottom-[50%] translate-y-[0.3125rem] left-0 w-full items-center gap-[0.5rem]"
  >
    <span class="w-[0.625rem] h-[0.625rem] rounded-full bg-brand-main"></span>
    <span class="flex-1 h-[0.1875rem] bg-slate-300"></span>
  </div>

  {{!-- TOP --}}
  <div
    class="relative flex items-end
    {{#if reverse}}order-2 smx:order-1{{else}}order-1{{/if}}"
  >
    {{#if reverse}}
    <div class="flex flex-col gap-[0.5rem] ml-auto">
      <h3 class="text-body font-unbounded text-light-base uppercase">
        {{title}}
      </h3>
      <span class="text-[0.875rem] text-light-secondary leading-[1.6]">
        {{text}}
      </span>
    </div>
    {{else}}
    <img
      src="{{image}}"
      class="w-full aspect-[372/180] mds:aspect-[161/180] md:aspect-[322/180] object-cover"
    />

    {{!--default divider --}}
    <div
      class="flex smx:hidden absolute bottom-[-1.4063rem] translate-y-[0.3125rem] left-0 w-full items-center gap-[0.5rem]"
    >
      <span class="w-[0.625rem] h-[0.625rem] rounded-full bg-brand-main"></span>
      <span class="flex-1 h-[0.1875rem] bg-slate-300"></span>
    </div>

    {{/if}}
  </div>

  {{!-- BOTTOM --}}
  <div
    class="relative flex items-start
    {{#if reverse}}order-1 smx:order-2{{else}}order-2{{/if}}"
  >
    {{#if reverse}}
    <img
      src="{{image}}"
      class="w-full aspect-[372/180] mds:aspect-[161/180] md:aspect-[322/180] object-cover"
    />

      {{!--default divider --}}
    <div class="flex smx:hidden absolute bottom-[-1.4063rem] translate-y-[0.3125rem] left-0 w-full items-center gap-[0.5rem]">
      <span class="w-[0.625rem] h-[0.625rem] rounded-full bg-brand-main"></span>
      <span class="flex-1 h-[0.1875rem] bg-slate-300"></span>
    </div>

    {{else}}
    <div class="flex flex-col gap-[0.5rem]">
      <h3 class="text-body font-unbounded text-light-base uppercase">
        {{title}}
      </h3>
      <span class="text-[0.875rem] text-light-secondary leading-[1.6]">
        {{text}}
      </span>
    </div>
    {{/if}}
  </div>
</div>
