<div class="input-field relative w-full">

  <input
    type="{{type}}"
    name="{{name}}"
    placeholder="{{placeholder}}"

    class="
      {{class}}
      w-full 
      rounded-full             
      bg-white
      border-[0.0625rem] border-slate-300

      focus:outline-none 
      focus:ring-2 focus:ring-blue-200 
      focus:border-brand-one

      transition
    "

    {{#if value}}value="{{value}}"{{/if}}
    {{#if required}}required{{/if}}
    {{#if disabled}}disabled{{/if}}

    data-input

    {{#if isDate}}
      data-datepicker
      readonly
    {{/if}}
  />

  {{#if icon}}
    <button
      type="button"
      class="absolute right-4 top-1/2 -translate-y-1/2"
      data-trigger
    >
      <svg class="w-5 h-5 text-gray-400 pointer-events-none">
        <use href="/icons/sprite/sprite.svg#{{icon}}"></use>
      </svg>
    </button>
  {{/if}}

</div>